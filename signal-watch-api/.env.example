ANTHROPIC_API_KEY=sk-ant-...
BRAVE_SEARCH_API_KEY=...
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/signalwatch
JWT_SECRET=change-me-to-a-random-secret

# Comma-separated browser origins allowed to call the API (web frontends).
# Defaults to localhost dev origins if unset. Native iOS clients ignore CORS.
# CORS_ALLOW_ORIGINS=https://app.signalwatch.com,https://www.signalwatch.com

# Email OTP delivery (optional). If SMTP_HOST is unset, sign-in codes are
# written to the application log instead of emailed (dev mode).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=...
# SMTP_FROM=Signal Watch <no-reply@signalwatch.app>
# SMTP_USE_TLS=true
